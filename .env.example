# Configurație Bază de Date (Supabase PostgreSQL)
# Adaugă URL-urile în .env.local

# Pooler (transaction, port 6543) pentru runtime pe serverless (Folosit de Prisma Client la runtime):
DATABASE_URL="postgresql://postgres.[PROIECT]:[PAROLA]@aws-0-[REGIUNE].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Conexiune directă (port 5432) — necesară pentru generare schema (`npx prisma db push`):
DIRECT_URL="postgresql://postgres.[PROIECT]:[PAROLA]@aws-0-[REGIUNE].pooler.supabase.com:5432/postgres"

# Secret pentru sesiuni:
SESSION_SECRET="un-secret-foarte-lung-aici"
